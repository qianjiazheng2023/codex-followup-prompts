{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/scripts/inject_followup_instruction.py",
            "commandWindows": "python -X utf8 \"%PLUGIN_ROOT%\\scripts\\inject_followup_instruction.py\"",
            "timeout": 5,
            "statusMessage": "正在准备追问建议"
          }
        ]
      }
    ]
  }
}
